;; EXPECT: ok
;; DERIVE_AC_EQS: on
;; CHECK_AC_BASIS: on
;; Nilpotent order-3 semantic self-critical-pair. From x3(a,b)=c and x+x+x=e,
;; adding two copies of a to both sides gives b = x3(a,a,c); symmetrically a = x3(b,b,c).
(sort E)
(function e () E)
(function a () E)
(function b () E)
(function c () E)
(function x3 (E) E :assoc :comm :nilpotent 3 :identity (e))
(let ab (x3 (a) (b)))
(union ab (c))
(let aac (x3 (a) (a) (c)))
(let bbc (x3 (b) (b) (c)))
(run 6)
(check (= (b) aac))
(check (= (a) bbc))
