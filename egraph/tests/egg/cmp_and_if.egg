;; EXPECT: ok
;; TYPES: machine
(datatype Val (Num i64))
(datatype Expr (If Expr Expr Expr) (Lit Val) (B bool))

(rewrite (If (B c) (Lit (Num x)) (Lit (Num y)))
         (Lit (Num (i64::if c x y))))

(let e (If (B true) (Lit (Num 10)) (Lit (Num 20))))
(run 10)
(check (= e (Lit (Num 10))))

(let f (If (B false) (Lit (Num 10)) (Lit (Num 20))))
(run 10)
(check (= f (Lit (Num 20))))
