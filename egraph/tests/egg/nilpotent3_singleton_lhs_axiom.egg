;; EXPECT: ok
;; DERIVE_AC_EQS: on
;; CHECK_AC_BASIS: on
;; Axiom pair whose second reduct EMPTIES to the unit (adversarial analysis B.2): the rule
;; x3(a,a) = b has singleton LHS {a:2}; the pair for a (m=2, n−m=1) is
;; (f({b,a}), f({} ⊎ {e})) — so x3(a,b) = e. Semantically a² = b ⟹ a·b = a³ = e.
(sort E)
(function e () E)
(function a () E)
(function b () E)
(function x3 (E) E :assoc :comm :nilpotent 3 :identity (e))
(let t (x3 (a) (a)))
(union t (b))
(let u (x3 (a) (b)))
(run 5)
(check (= u (e)))
