;; EXPECT: ok
;; DERIVE_AC_EQS: on
;; CHECK_AC_BASIS: on
;; General-order nilpotent axiom pairs (n = 3; Kapur-conformance fix W3 (spec ¬ß3 table)). From x3(a,b) = c, the
;; pair for a (m = 1, n‚àím = 2) is (f({c,a,a}), f({b})): x3(a,a,c) = b. Semantically
;; a¬≥ = e and c = a‚àòb give a‚àòa‚àòc = a‚àòa‚àòa‚àòb = b.
(sort E)
(function e () E)
(function a () E)
(function b () E)
(function c () E)
(function x3 (E) E :assoc :comm :nilpotent 3 :identity (e))

(let t_ab (x3 (a) (b)))
(union t_ab (c))
(let t_aac (x3 (a) (a) (c)))
(let t_bbc (x3 (b) (b) (c)))

(run 5)
(check (= t_aac (b)))
(check (= t_bbc (a)))
