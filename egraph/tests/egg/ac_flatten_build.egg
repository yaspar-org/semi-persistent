;; EXPECT: ok
;; Build-side AC flattening (WF_flat, design §6c): a nested same-op term flattens to
;; the canonical flat multiset, so the nesting is invisible. No completion needed; this
;; is plain canonicalization in `add`. (AC_COMPLETE stays off.)

(sort E)
(function Add (E) E :assoc-comm)
(function a () E)
(function b () E)
(function c () E)
(function d () E)

;; Nested same-op constructions all canonicalize to the same flat node.
(check (= (Add (Add (a) (b)) (c)) (Add (a) (b) (c))))
(check (= (Add (a) (Add (b) (c))) (Add (a) (b) (c))))
(check (= (Add (Add (a) (b)) (Add (c) (d))) (Add (a) (b) (c) (d))))

;; Deeper nesting flattens to a fixpoint.
(check (= (Add (Add (Add (a) (b)) (c)) (d)) (Add (a) (b) (c) (d))))

;; Multiplicity is preserved through flattening: Add(Add(a,a), b) = {a:2, b:1}.
(check (= (Add (Add (a) (a)) (b)) (Add (a) (a) (b))))

;; Negative control: flattening does not conflate distinct flat terms.
(check (!= (Add (a) (b)) (Add (a) (c))))
