;; EXPECT: ok
;; DERIVE_AC_EQS: on
;; CHECK_AC_BASIS: on
;; The general n−m axiom-pair arm with m > 1 (adversarial analysis B.3): from
;; x3(a,a,b) = c, the pair for a (m=2, n−m=1) is (f({c,a}), f({b})): x3(a,c) = b.
;; Semantically a²b = c ⟹ a·c = a³·b = b. (nilpotent3_rule_axiom_cp only tests m = 1.)
(sort E)
(function e () E)
(function a () E)
(function b () E)
(function c () E)
(function x3 (E) E :assoc :comm :nilpotent 3 :identity (e))
(let t (x3 (a) (a) (b)))
(union t (c))
(let u (x3 (a) (c)))
(run 5)
(check (= u (b)))
