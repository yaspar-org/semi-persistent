;; EXPECT: ok
;; TYPES: machine
;; Tests bool ops via rewrites
(datatype E (And bool bool) (Or bool bool) (Not bool) (BIf bool bool bool)
            (RB bool))

(rewrite (And x y)   (RB (and x y)))
(rewrite (Or x y)    (RB (or x y)))
(rewrite (Not x)     (RB (not x)))
(rewrite (BIf c x y) (RB (bool::if c x y)))

(let a (And true true))   (run 10) (check (= a (RB true)))
(let b (And true false))  (run 10) (check (= b (RB false)))
(let c (Or false true))   (run 10) (check (= c (RB true)))
(let d (Or false false))  (run 10) (check (= d (RB false)))
(let e (Not true))        (run 10) (check (= e (RB false)))
(let f (Not false))       (run 10) (check (= f (RB true)))
(let g (BIf true true false))  (run 10) (check (= g (RB true)))
(let h (BIf false true false)) (run 10) (check (= h (RB false)))
