;; EXPECT: ok
;; DERIVE_AC_EQS: on
;; Composable basic tags `:assoc :comm` must behave exactly like the `:assoc-comm` alias:
;; the §4b superposition equality still derives.
(sort E)
(function add (E) E :assoc :comm)
(function a () E)
(function b () E)
(function c () E)
(function d () E)
(function e () E)
(let s_ab (add (a) (b)))
(let s_bd (add (b) (d)))
(union s_ab (c))
(union s_bd (e))
(let s_cd (add (c) (d)))
(let s_ae (add (a) (e)))
(run 5)
(check (= s_cd s_ae))
