;; EXPECT: ok
;; DERIVE_AC_EQS: on
;; Group inverse pair cancellation (gate flipped 2026-07-10): :inverse with :identity
;; drives x ∘ inv(x) = e at build and in completion, so add(a, neg(a)) reduces to zero.
(sort E)
(function zero () E)
(function a () E)
(function neg (E) E)
(function add (E) E :assoc :comm :identity (zero) :inverse neg)
(let a_neg_a (add (a) (neg (a))))
(run 5)
(check (= a_neg_a (zero)))
