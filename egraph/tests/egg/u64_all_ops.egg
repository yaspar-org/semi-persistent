;; EXPECT: ok
;; TYPES: machine
;; Tests u64 ops via rewrites
(datatype E
  (Add u64 u64) (Sub u64 u64) (Mul u64 u64) (Div u64 u64) (Rem u64 u64)
  (Min u64 u64) (Max u64 u64)
  (Lt u64 u64) (Le u64 u64) (Gt u64 u64) (Ge u64 u64) (Eq u64 u64) (Ne u64 u64)
  (WA u64 u64) (WS u64 u64) (SA u64 u64) (SS u64 u64)
  (If bool u64 u64)
  (RN u64) (RB bool))

(rewrite (Add x y) (RN (u64::+ x y)))
(rewrite (Sub x y) (RN (u64::- x y)))
(rewrite (Mul x y) (RN (u64::* x y)))
(rewrite (Div x y) (RN (u64::/ x y)))
(rewrite (Rem x y) (RN (u64::% x y)))
(rewrite (Min x y) (RN (u64::min x y)))
(rewrite (Max x y) (RN (u64::max x y)))
(rewrite (Lt x y)  (RB (u64::< x y)))
(rewrite (Le x y)  (RB (u64::<= x y)))
(rewrite (Gt x y)  (RB (u64::> x y)))
(rewrite (Ge x y)  (RB (u64::>= x y)))
(rewrite (Eq x y)  (RB (u64::== x y)))
(rewrite (Ne x y)  (RB (u64::!= x y)))
(rewrite (WA x y)  (RN (u64::wrapping_add x y)))
(rewrite (WS x y)  (RN (u64::wrapping_sub x y)))
(rewrite (SA x y)  (RN (u64::saturating_add x y)))
(rewrite (SS x y)  (RN (u64::saturating_sub x y)))
(rewrite (If c x y) (RN (u64::if c x y)))

(let a (Add 10 20))   (run 10) (check (= a (RN 30)))
(let b (Sub 20 7))    (run 10) (check (= b (RN 13)))
(let c (Mul 6 7))     (run 10) (check (= c (RN 42)))
(let d (Lt 3 7))      (run 10) (check (= d (RB true)))
(let e (Eq 5 5))      (run 10) (check (= e (RB true)))
(let f (WA 18446744073709551615 1)) (run 10) (check (= f (RN 0)))
(let g (WS 0 1))      (run 10) (check (= g (RN 18446744073709551615)))
(let h (SA 18446744073709551615 1)) (run 10) (check (= h (RN 18446744073709551615)))
(let i (SS 0 1))      (run 10) (check (= i (RN 0)))
(let j (If true 10 20)) (run 10) (check (= j (RN 10)))
