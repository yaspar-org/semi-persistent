;; EXPECT: ok
;; DERIVE_AC_EQS: on
;; CHECK_AC_BASIS: on
;; Idempotent per-rule AXIOM critical pairs (Kapur Lemma 4.1(ii); Kapur-conformance fix W3 (spec ¬ß3 table)):
;; superposing a rule f(M)‚Üíf(N) with x‚àòx = x gives, per a ‚àà M, the pair (f(M), f(N‚à™{a})).
;; or(a,b) = c  ‚üπ  or(a,c) = c and or(b,c) = c  (a‚à®c = a‚à®a‚à®b = a‚à®b = c). The derived
;; rule {a,c}‚Üí{c} must itself superpose with ordinary rules: with or(c,d) = f,
;; or(a,f) = f follows (a‚à®f = a‚à®c‚à®d = c‚à®d = f).
(sort E)
(function Or (E) E :assoc-comm-idem)
(function a () E)
(function b () E)
(function c () E)
(function d () E)
(function f () E)

(let s_ab (Or (a) (b)))
(union s_ab (c))
(let s_ac (Or (a) (c)))
(let s_bc (Or (b) (c)))
(let s_cd (Or (c) (d)))
(union s_cd (f))
(let s_af (Or (a) (f)))

(run 5)
(check (= s_ac (c)))
(check (= s_bc (c)))
(check (= s_af (f)))
