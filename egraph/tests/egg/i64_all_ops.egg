;; EXPECT: ok
;; TYPES: machine
;; Tests i64 ops via rewrites (prim ops in RHS only)
(datatype E
  (Add i64 i64) (Sub i64 i64) (Mul i64 i64) (Div i64 i64) (Rem i64 i64)
  (Neg i64) (Abs i64) (Min i64 i64) (Max i64 i64)
  (Lt i64 i64) (Le i64 i64) (Gt i64 i64) (Ge i64 i64) (Eq i64 i64) (Ne i64 i64)
  (If bool i64 i64)
  (RN i64) (RB bool))

(rewrite (Add x y) (RN (i64::+ x y)))
(rewrite (Sub x y) (RN (i64::- x y)))
(rewrite (Mul x y) (RN (i64::* x y)))
(rewrite (Div x y) (RN (i64::/ x y)))
(rewrite (Rem x y) (RN (i64::% x y)))
(rewrite (Neg x)   (RN (i64::neg x)))
(rewrite (Abs x)   (RN (i64::abs x)))
(rewrite (Min x y) (RN (i64::min x y)))
(rewrite (Max x y) (RN (i64::max x y)))
(rewrite (Lt x y)  (RB (i64::< x y)))
(rewrite (Le x y)  (RB (i64::<= x y)))
(rewrite (Gt x y)  (RB (i64::> x y)))
(rewrite (Ge x y)  (RB (i64::>= x y)))
(rewrite (Eq x y)  (RB (i64::== x y)))
(rewrite (Ne x y)  (RB (i64::!= x y)))
(rewrite (If c x y) (RN (i64::if c x y)))

(let a (Add 10 20))   (run 10) (check (= a (RN 30)))
(let b (Sub 20 7))    (run 10) (check (= b (RN 13)))
(let c (Mul 6 7))     (run 10) (check (= c (RN 42)))
(let d (Div 20 3))    (run 10) (check (= d (RN 6)))
(let e (Rem 20 3))    (run 10) (check (= e (RN 2)))
(let f (Neg 5))        (run 10) (check (= f (RN -5)))
(let g (Abs -7))       (run 10) (check (= g (RN 7)))
(let h (Min 3 7))     (run 10) (check (= h (RN 3)))
(let i (Max 3 7))     (run 10) (check (= i (RN 7)))
(let j (Lt 3 7))      (run 10) (check (= j (RB true)))
(let k (Lt 7 3))      (run 10) (check (= k (RB false)))
(let l (Le 3 3))      (run 10) (check (= l (RB true)))
(let m (Gt 7 3))      (run 10) (check (= m (RB true)))
(let n (Ge 3 3))      (run 10) (check (= n (RB true)))
(let o (Eq 5 5))      (run 10) (check (= o (RB true)))
(let p (Ne 5 6))      (run 10) (check (= p (RB true)))
(let q (If true 10 20))  (run 10) (check (= q (RN 10)))
(let r (If false 10 20)) (run 10) (check (= r (RN 20)))
