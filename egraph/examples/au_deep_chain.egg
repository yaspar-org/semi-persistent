; Deep linear unary chains: f^64(a) vs f^64(b).
; The anti-unifier factors the whole chain through f with a single
; Variants leaf: f^64(Variants(a, b)) has size 64 + 2 = 66.
; Mirrors au_basic.egg style; run with the semi-persistent CLI.
(sort E)
(function a () E)
(function b () E)
(function f (E) E)

(let l0 (a))
(let r0 (b))
(let l1 (f l0))
(let r1 (f r0))
(let l2 (f l1))
(let r2 (f r1))
(let l3 (f l2))
(let r3 (f r2))
(let l4 (f l3))
(let r4 (f r3))
(let l5 (f l4))
(let r5 (f r4))
(let l6 (f l5))
(let r6 (f r5))
(let l7 (f l6))
(let r7 (f r6))
(let l8 (f l7))
(let r8 (f r7))
(let l9 (f l8))
(let r9 (f r8))
(let l10 (f l9))
(let r10 (f r9))
(let l11 (f l10))
(let r11 (f r10))
(let l12 (f l11))
(let r12 (f r11))
(let l13 (f l12))
(let r13 (f r12))
(let l14 (f l13))
(let r14 (f r13))
(let l15 (f l14))
(let r15 (f r14))
(let l16 (f l15))
(let r16 (f r15))
(let l17 (f l16))
(let r17 (f r16))
