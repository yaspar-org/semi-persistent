(let r59 (f r58))
(let l60 (f l59))
(let r60 (f r59))
(let l61 (f l60))
(let r61 (f r60))
(let l62 (f l61))
(let r62 (f r61))
(let l63 (f l62))
(let r63 (f r62))
(let l64 (f l63))
(let r64 (f r63))

; Show the anti-unifier under both algorithms.
(antiunify l64 r64 :algorithm exact)
(antiunify l64 r64 :algorithm uct :playouts 1000)

; checkau: the chain must factor to full depth — size exactly 64 + 2.
(checkau l64 r64 :max_size 66 :algorithm exact)
; UCT's initial greedy rollout composes the same fully factored term.
(checkau l64 r64 :max_size 66 :algorithm uct :playouts 1000)
